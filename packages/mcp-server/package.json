{
  "name": "@phantom/mcp-server",
  "version": "0.1.8",
  "description": "MCP Server for Phantom Wallet",
  "repository": {
    "type": "git",
    "url": "https://github.com/phantom/phantom-connect-sdk",
    "directory": "packages/mcp-server"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "phantom-mcp": "./dist/cli.js"
  },
  "scripts": {
    "?pack-release": "When https://github.com/changesets/changesets/issues/432 has a solution we can remove this trick",
    "pack-release": "rimraf ./_release && yarn pack && mkdir ./_release && tar zxvf ./package.tgz --directory ./_release && rm ./package.tgz",
    "build": "rimraf ./dist && tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "check-types": "yarn tsc --noEmit",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "pack:desktop": "yarn build && mcpb pack"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "eslint": "8.53.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.1.2",
    "tsup": "^6.7.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@phantom/api-key-stamper": "workspace:^",
    "@phantom/base64url": "workspace:^",
    "@phantom/client": "workspace:^",
    "@phantom/constants": "workspace:^",
    "@phantom/crypto": "workspace:^",
    "@phantom/server-sdk": "workspace:^",
    "@phantom/utils": "workspace:^",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.5",
    "axios": "^1.6.7",
    "bs58": "^6.0.0",
    "openid-client": "^5.6.5"
  },
  "files": [
    "dist",
    "manifest.json",
    "icon.png"
  ],
  "publishConfig": {
    "directory": "_release/package"
  }
}
